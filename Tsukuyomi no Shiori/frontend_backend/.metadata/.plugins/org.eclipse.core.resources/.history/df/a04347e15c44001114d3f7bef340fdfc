package com.tsukuyomi.shiori.repository;

import com.tsukuyomi.shiori.entity.BookMood;
import org.springframework.data.jpa.repository.JpaRepository;

import java.util.List;
import java.util.Optional;

public interface BookMoodRepository extends JpaRepository<BookMood, Long> {

    List<BookMood> findByBookId(Long bookId);

    List<BookMood> findByMoodTagId(Long moodTagId);

    boolean existsByBookIdAndMoodTagId(Long bookId, Long moodTagId);

    Optional<BookMood> findByBookIdAndMoodTagId(Long bookId, Long moodTagId);
}
