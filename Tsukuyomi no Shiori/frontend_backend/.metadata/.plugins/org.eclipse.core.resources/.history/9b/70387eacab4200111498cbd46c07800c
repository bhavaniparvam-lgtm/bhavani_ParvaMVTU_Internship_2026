package com.tsukuyomi.shiori.dto;

public class LoginStepResponse {

    private Long userId;
    private String displayName;
    private String email;
    private String secretQuestion;
    private boolean requiresSecretQuestion;

    public LoginStepResponse() {
    }

    public LoginStepResponse(Long userId, String displayName, String email, String secretQuestion, boolean requiresSecretQuestion) {
        this.userId = userId;
        this.displayName = displayName;
        this.email = email;
        this.secretQuestion = secretQuestion;
        this.requiresSecretQuestion = requiresSecretQuestion;
    }

    public Long getUserId() {
        return userId;
    }

    public void setUserId(Long userId) {
        this.userId = userId;
    }

    public String getDisplayName() {
        return displayName;
    }

    public void setDisplayName(String displayName) {
        this.displayName = displayName;
    }

    public String getEmail() {
        return email;
    }

    public void setEmail(String email) {
        this.email = email;
    }

    public String getSecretQuestion() {
        return secretQuestion;
    }

    public void setSecretQuestion(String secretQuestion) {
        this.secretQuestion = secretQuestion;
    }

    public boolean isRequiresSecretQuestion() {
        return requiresSecretQuestion;
    }

    public void setRequiresSecretQuestion(boolean requiresSecretQuestion) {
        this.requiresSecretQuestion = requiresSecretQuestion;
    }
}